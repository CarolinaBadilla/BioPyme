generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")  // ← Importante para migraciones

}

// ============================================
// MODELOS GEOGRÁFICOS
// ============================================

model Region {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  color       String     @default("#3b82f6")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  departments Department[]

  @@map("regions")
}

model Department {
  id                              Int        @id @default(autoincrement())
  name                            String     @unique
  regionId                        Int
  totalViviendas                  Int?       @default(0)  // ← Agregar ? y default
  viviendasColectivas             Int?       @default(0)
  viviendasParticulares           Int?       @default(0)
  viviendasParticularesMoradores  Int?       @default(0)
  hogares                         Int?       @default(0)
  poblacionTotal                  Int?       @default(0)
  poblacionViviendasParticulares  Int?       @default(0)
  poblacionViviendasColectivas    Int?       @default(0)
  poblacionCalle                  Int?       @default(0)
  mujeres                         Int?       @default(0)
  varones                         Int?       @default(0)
  color                           String     @default("#60a5fa")
  createdAt                       DateTime   @default(now())
  updatedAt                       DateTime   @updatedAt

  region      Region     @relation(fields: [regionId], references: [id])
  cities      City[]

  @@map("departments")
}

model City {
  id           Int        @id @default(autoincrement())
  name         String     @unique
  departmentId Int
  latitude     Float
  longitude    Float
  isCapital    Boolean    @default(false)
  population   Int?       @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  department   Department @relation(fields: [departmentId], references: [id])

  @@map("cities")
}

// ============================================
// MODELOS DE USUARIOS Y EMPRESAS
// ============================================

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String
  name      String?
  companyId Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Company {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  cuit        String  @unique
  address     String
  latitude    Float?
  longitude   Float?
  type        String  @default("PLANTA")
  cityId      Int?
  
  // Precios y costos
  biodieselPrice    Float   @default(0)
  fossilDieselPrice Float   @default(0)
  variableCost      Float   @default(0)
  fixedCost         Float   @default(0)
  
  // Capacidad
  nominalCapacityRange String @default("")
  productionMonth   Int     @default(0)
  
  // Stock y demanda
  stockLiters       Int     @default(0)
  monthlyDemand     Int     @default(0)
  dailyCapacity     Int     @default(0)
  
  // Cámara Biopyme
  knowsChamber      Boolean @default(false)
  isAssociated      Boolean @default(false)
  wantsToAssociate  Boolean @default(false)
  
  // Estado del proyecto
  projectStatus     String  @default("")
  
  // Tecnología
  equipment         String  @default("")
  
  // Habilitaciones
  hasSecEnergyLicense Boolean @default(false)
  hasSelloB100       Boolean @default(false)
  secEnergyProcessStatus String @default("")
  
  // Control de calidad
  qualityControlled   Boolean @default(false)
  hasAnalysis         Boolean @default(false)
  satisfactoryResult  Boolean @default(false)
  labReference        String  @default("")
  
  // Tipo de aceite
  oilType            String  @default("")
  
  // Certificaciones
  qualityCertified  Boolean @default(false)
  selloB100         Boolean @default(false)
  
  // Empleos
  employees         Int     @default(0)
  
  isApproved Boolean @default(false)
  ownerId     Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("companies")
}

// Agregar después del modelo Company

model Localidad {
  id          Int     @id @default(autoincrement())
  nombre      String
  habitantes  Int
  departamento String
  region      String
  intendente  String
  vinculo     String?
  empresas    String?
  latitud     Float
  longitud    Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("localidades")
}

model YpfStation {
  id        Int     @id @default(autoincrement())
  nombre    String
  direccion String
  telefono  String?
  latitud   Float
  longitud  Float
  localidad   String? 
  departamento String? 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ypf_stations")
}

model EstacionBlanca {   // 👈 Con mayúscula y singular
  id          Int     @id @default(autoincrement())
  nombre      String
  direccion   String
  telefono    String?
  latitud     Float
  longitud    Float
  localidad   String?
  departamento String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("estaciones_blancas")  // 👈 Nombre de la tabla en la BD
}

model Request {
  id          Int      @id @default(autoincrement())
  companyId   Int
  status      String   @default("PENDING")
  documentUrl String?
  adminNotes  String?
  reviewedBy  Int?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("requests")
}